# ─────────────────────────────────────────────
#  CET Mock Test Portal — Environment Variables
#  For Render.com deployment
#
#  Render auto-detects this file's keys when you click
#  "Add from .env" in the Environment tab — but you must
#  paste actual values there, Render does NOT read this
#  file directly from the repo at runtime.
# ─────────────────────────────────────────────

# ── Server ─────────────────────────────────────
# Render injects PORT automatically — do not set this manually on Render.
# PORT=8080

# ── Database (SQLite file path) ───────────────
# IMPORTANT: Render's filesystem is ephemeral on free/starter instances —
# the SQLite file will be WIPED on every redeploy or restart unless you
# attach a Render Disk and point DB_PATH at a mounted path, e.g. /data/cetportal.db
DB_PATH=/data/cetportal.db

# Schema mode: "update" for first deploy, switch to "validate" after
DDL_AUTO=update

# ── Thymeleaf ──────────────────────────────────
THYMELEAF_CACHE=true

# ── File Uploads (PDFs + rendered question images) ──
# Same ephemeral-disk caveat as DB_PATH — mount a Render Disk and point here
UPLOAD_DIR=/data/uploads
PAGES_DIR=/data/uploads/pages

# ── Admin Seed Credentials (used only on first boot) ──
# CHANGE THESE before going live.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisStrongPassword123!
ADMIN_FULL_NAME=Administrator
ADMIN_EMAIL=admin@yourdomain.com

# ── Institute Branding ─────────────────────────
INSTITUTE_NAME=Aparaitech Coaching Institute
INSTITUTE_TAGLINE=Excellence in CET / NEET / JEE Preparation
INSTITUTE_LOGO_URL=
INSTITUTE_LOGO_TEXT=AI
INSTITUTE_ADDRESS=Baramati, Pune, Maharashtra
INSTITUTE_PHONE=+91 98765 43210
INSTITUTE_EMAIL=info@aparaitech.com
INSTITUTE_COPYRIGHT=Aparaitech Software

# ── Logging ────────────────────────────────────
LOG_LEVEL_APP=INFO
LOG_LEVEL_ROOT=WARN
